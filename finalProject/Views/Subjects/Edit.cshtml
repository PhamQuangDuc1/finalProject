@model SubjectFormViewModel

@{
    ViewData["Title"] = "Sửa môn học";
}

<section class="card-panel">
    <h1 class="section-title">Sửa môn học</h1>
    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="Id" />
        <partial name="_SubjectForm" model="Model" />
        <div class="form-check mb-3">
            <input asp-for="IsActive" class="form-check-input" />
            <label asp-for="IsActive" class="form-check-label">Đang hoạt động</label>
        </div>
        <button type="submit" class="btn btn-primary">Lưu</button>
        <a class="btn btn-outline-secondary" asp-action="Index">Hủy</a>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

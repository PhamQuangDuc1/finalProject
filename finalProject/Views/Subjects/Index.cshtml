@model IReadOnlyList<BLL.DTOs.SubjectDto>

@{
    ViewData["Title"] = "Môn học";
}

<h1 class="h3 mb-3">Môn học</h1>

<table class="table table-striped align-middle">
    <thead>
        <tr>
            <th>Mã môn học</th>
            <th>Tên môn học</th>
            <th>Bộ môn</th>
        </tr>
    </thead>
    <tbody>
    @if (Model.Count == 0)
    {
        <tr>
            <td colspan="3" class="text-muted">Chưa có môn học nào được tạo.</td>
        </tr>
    }
    else
    {
        @foreach (var subject in Model)
        {
            <tr>
                <td>@subject.Code</td>
                <td>@subject.Name</td>
                <td>@subject.DepartmentName</td>
            </tr>
        }
    }
    </tbody>
</table>

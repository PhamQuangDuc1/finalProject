@model BLL.DTOs.PaymentDto
@using DAL.Entities

@{
    ViewData["Title"] = "Thanh toán VNPay";
    var expiresAt = Model.ExpiresAt?.ToLocalTime();
    var isPending = Model.Status == PaymentStatus.Pending;
    var displayAmount = ((long)(Model.Amount * 100)).ToString("N0");
    
    // Generate payment URL for QR code
    var payUrl = Model.GatewayPayUrl ?? "";
    var qrData = !string.IsNullOrEmpty(payUrl) 
        ? Uri.EscapeDataString(payUrl)
        : "";
    var qrUrl = !string.IsNullOrEmpty(qrData) 
        ? $"https://api.qrserver.com/v1/create-qr-code/?size=300x300&data={qrData}"
        : "";
}

<div class="admin-page">
    <div class="admin-hero">
        <div>
            <p class="dashboard-kicker">Thanh toán VNPay</p>
            <h1>Hoàn tất thanh toán</h1>
            <p>Quét mã QR bên dưới bằng ứng dụng ngân hàng hoặc ví điện tử để thanh toán. Sau khi thanh toán thành công, gói sẽ tự động kích hoạt.</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-primary">← Quay lại</a>
    </div>

    <div class="row g-4 justify-content-center">
        <div class="col-lg-5">
            <div class="card-panel admin-panel text-center">
                <div class="panel-heading">
                    <p class="dashboard-kicker">Mã đơn</p>
                    <h2 class="section-title">#@Model.Id</h2>
                </div>

                @if (!string.IsNullOrEmpty(qrUrl))
                {
                    <img src="@qrUrl" alt="VNPay QR Code" class="img-fluid rounded mb-3" style="max-width: 280px; margin: 0 auto; border: 3px solid #eee; border-radius: 12px;" />
                    <p class="text-muted small mb-2">
                        <i class="fas fa-qrcode me-1"></i>Quét mã QR bằng ứng dụng ngân hàng
                    </p>
                }
                else
                {
                    <div class="alert alert-warning mb-3">
                        <i class="fas fa-exclamation-triangle me-2"></i>
                        Không thể tạo mã QR. Vui lòng liên hệ hỗ trợ.
                    </div>
                }

                <p class="display-5 fw-bold text-primary mb-1">@Model.Amount.ToString("N0") đ</p>
                <p class="text-muted small mb-3">@Model.SubscriptionPackageName</p>

                @if (!string.IsNullOrEmpty(Model.GatewayPayUrl))
                {
                    <div class="d-grid gap-2 mb-3">
                        <a href="@Model.GatewayPayUrl" class="btn btn-primary btn-lg" target="_blank">
                            <i class="fas fa-external-link-alt me-2"></i>Thanh toán ngay với VNPay
                        </a>
                    </div>
                }

                @if (expiresAt is not null)
                {
                    <p class="text-muted small mb-0">
                        <i class="fas fa-clock me-1"></i>
                        Phiên thanh toán hết hạn lúc <strong>@expiresAt.Value.ToString("HH:mm:ss")</strong>
                    </p>
                }
            </div>

            @if (isPending)
            {
                <div class="card-panel admin-panel mt-3">
                    <div class="panel-heading">
                        <h2 class="section-title">Hướng dẫn thanh toán</h2>
                    </div>
                    <ol class="mb-0 small">
                        <li class="mb-2">Mở ứng dụng <strong>Internet Banking</strong> hoặc <strong>Ví điện tử</strong> trên điện thoại</li>
                        <li class="mb-2">Chọn chức năng <strong>"Quét mã QR"</strong></li>
                        <li class="mb-2">Quét mã QR hiển thị bên trên</li>
                        <li class="mb-2">Xác nhận thanh toán với số tiền <strong>@Model.Amount.ToString("N0") đ</strong></li>
                        <li class="mb-0">Sau khi thanh toán thành công, gói sẽ tự động kích hoạt</li>
                    </ol>
                </div>
            }
        </div>

        <div class="col-lg-5">
            <div class="card-panel admin-panel">
                <div class="panel-heading">
                    <p class="dashboard-kicker">Chi tiết đơn hàng</p>
                    <h2 class="section-title">Thông tin thanh toán</h2>
                </div>
                <dl class="row mb-0">
                    <dt class="col-sm-4">Gói dịch vụ</dt>
                    <dd class="col-sm-8">@Model.SubscriptionPackageName</dd>
                    <dt class="col-sm-4">Số tiền</dt>
                    <dd class="col-sm-8 fs-4 fw-bold text-primary">@Model.Amount.ToString("N0") đ</dd>
                    <dt class="col-sm-4">Cổng thanh toán</dt>
                    <dd class="col-sm-8">
                        <span class="badge bg-info">
                            <i class="fas fa-shield-alt me-1"></i>@Model.GatewayLabel
                        </span>
                    </dd>
                    <dt class="col-sm-4">Mã đơn hàng</dt>
                    <dd class="col-sm-8"><span class="admin-code">@Model.GatewayOrderId</span></dd>
                    <dt class="col-sm-4">Trạng thái</dt>
                    <dd class="col-sm-8">
                        <span class="badge rounded-pill @GetStatusClass(Model.Status)">@Model.StatusLabel</span>
                    </dd>
                    <dt class="col-sm-4">Ngày tạo</dt>
                    <dd class="col-sm-8">@Model.CreatedAt.ToLocalTime().ToString("g")</dd>
                    @if (Model.CompletedAt is not null)
                    {
                        <dt class="col-sm-4">Đã thanh toán</dt>
                        <dd class="col-sm-8">@Model.CompletedAt.Value.ToLocalTime().ToString("g")</dd>
                    }
                </dl>
            </div>

            @if (Model.Status == PaymentStatus.Completed)
            {
                <div class="alert alert-success mt-3">
                    <i class="fas fa-check-circle me-2"></i>
                    <strong>Thanh toán thành công!</strong> Gói của bạn đã được kích hoạt.
                </div>
            }

            <div class="d-flex gap-2 mt-3">
                <a asp-action="Index" class="btn btn-outline-primary">
                    <i class="fas fa-list me-2"></i>Quay lại danh sách
                </a>
                @if (Model.Status == PaymentStatus.Pending)
                {
                    <button type="button" class="btn btn-outline-danger" onclick="confirmCancel()">
                        <i class="fas fa-times me-2"></i>Hủy đơn
                    </button>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function confirmCancel() {
            if (confirm('Bạn có chắc muốn hủy đơn hàng này?')) {
                // For now, just show a message - actual cancel functionality can be added later
                alert('Tính năng hủy đơn đang được phát triển.');
            }
        }
        
        // Auto-refresh status every 10 seconds for pending payments
        @if (isPending)
        {
            <text>
            setTimeout(function() {
                location.reload();
            }, 30000); // Refresh every 30 seconds
            </text>
        }
    </script>
}

@functions {
    static string GetStatusClass(DAL.Entities.PaymentStatus status) => status switch
    {
        DAL.Entities.PaymentStatus.Completed => "text-bg-success",
        DAL.Entities.PaymentStatus.Pending => "text-bg-warning",
        DAL.Entities.PaymentStatus.Failed => "text-bg-danger",
        _ => "text-bg-secondary"
    };
}

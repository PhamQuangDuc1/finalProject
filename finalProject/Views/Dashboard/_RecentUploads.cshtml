@model IReadOnlyList<BLL.DTOs.RecentUploadDto>

@if (Model.Count == 0)
{
    <p class="text-muted mb-0">Chưa có tài liệu được tải lên.</p>
}
else
{
    <div class="list-stack">
        @foreach (var upload in Model)
        {
            <div class="list-row list-row-vertical">
                <div>
                    <strong>@upload.Title</strong>
                    <span>@upload.SubjectName</span>
                </div>
                <small>@upload.TeacherName · @upload.UploadedAt.ToLocalTime().ToString("g")</small>
            </div>
        }
    </div>
}

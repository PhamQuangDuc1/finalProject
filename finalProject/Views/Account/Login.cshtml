@model LoginViewModel

@{
    ViewData["Title"] = "Đăng nhập";
}

<section class="login-page" aria-label="Đăng nhập StudyMate AI">
    <div class="login-showcase">
        <a class="login-brand" asp-controller="Home" asp-action="Index">
            <span>✦</span>
            StudyMate AI
        </a>
        <div class="login-showcase-copy">
            <p class="login-kicker">Nền tảng học tập thông minh</p>
            <h1>Quản lý tài liệu, theo dõi tiến độ và học cùng AI trong một không gian.</h1>
            <p>
                StudyMate AI giúp nhà trường, giảng viên và sinh viên làm việc với tài liệu học tập
                nhanh hơn, rõ ràng hơn và có ngữ cảnh hơn.
            </p>
        </div>
        <div class="login-feature-grid" aria-label="Tính năng nổi bật">
            <span>Tóm tắt tài liệu</span>
            <span>Quiz thông minh</span>
            <span>Theo dõi chi phí AI</span>
            <span>Phân quyền rõ ràng</span>
        </div>
    </div>

    <div class="login-card-shell">
        <div class="auth-card login-card">
            <div class="login-card-header">
                <p class="login-kicker">Chào mừng trở lại</p>
                <h1>Đăng nhập</h1>
                <p>Truy cập không gian học tập và quản trị của StudyMate AI.</p>
            </div>

            <div class="login-demo-accounts" aria-label="Tài khoản test">
                <div class="login-demo-title">Tài khoản test</div>
                <div class="login-demo-list">
                    <span><strong>Admin</strong> admin / 123456</span>
                    <span><strong>Teacher A</strong> teacherA / 123456</span>
                    <span><strong>Teacher B</strong> teacherB / 123456</span>
                    <span><strong>Student</strong> student / 123456</span>
                </div>
            </div>

            <form asp-action="Login" method="post" class="login-form">
                <input type="hidden" asp-for="ReturnUrl" />
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="form-field">
                    <label asp-for="Username" class="form-label">Tên đăng nhập</label>
                    <input asp-for="Username" class="form-control" autocomplete="username" placeholder="Nhập tên đăng nhập" />
                    <span asp-validation-for="Username" class="text-danger"></span>
                </div>

                <div class="form-field">
                    <label asp-for="Password" class="form-label">Mật khẩu</label>
                    <input asp-for="Password" class="form-control" autocomplete="current-password" placeholder="Nhập mật khẩu" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <div class="login-form-row">
                    <div class="form-check">
                        <input asp-for="RememberMe" class="form-check-input" />
                        <label asp-for="RememberMe" class="form-check-label">Ghi nhớ đăng nhập</label>
                    </div>
                </div>

                <button type="submit" class="btn login-submit">
                    Đăng nhập
                    <svg viewBox="0 0 16 16" focusable="false" aria-hidden="true">
                        <path fill="currentColor" d="M6.22 3.22a.75.75 0 0 1 1.06 0l4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.75.75 0 1 1-1.06-1.06L9.94 8 6.22 4.28a.75.75 0 0 1 0-1.06Z" />
                    </svg>
                </button>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

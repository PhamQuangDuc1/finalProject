@model StudentDocumentsIndexViewModel

@{
    ViewData["Title"] = "Tài liệu học tập";
    var upcomingArchiveDocuments = Model.UpcomingArchiveDocuments;
    var nextArchiveDocument = upcomingArchiveDocuments.FirstOrDefault();
}

<div class="admin-page">
    <div class="admin-hero">
        <div>
            <p class="dashboard-kicker">Sinh viên</p>
            <h1>Tài liệu học tập</h1>
            <p>Danh sách tài liệu đã index, thuộc môn học đang hoạt động và sẵn sàng để xem hoặc tải xuống.</p>
        </div>
        <div class="admin-hero-stat">
            <span>Tài liệu</span>
            <strong>@Model.Documents.Count</strong>
        </div>
    </div>

    @if (TempData["StatusMessage"] is string statusMessage)
    {
        <div class="alert alert-info" role="alert">@statusMessage</div>
    }

    @if (nextArchiveDocument is not null)
    {
        <div class="alert alert-warning d-flex flex-column gap-1" role="alert">
            <strong>Có @upcomingArchiveDocuments.Count tài liệu sắp bị ẩn.</strong>
            <span>
                Gần nhất: <strong>@nextArchiveDocument.Title</strong>. @FormatArchiveWarning(nextArchiveDocument.ScheduledArchiveAtUtc!.Value). 
                Hãy xem hoặc tải xuống trước khi tài liệu không còn khả dụng.
            </span>
        </div>
    }

    <section class="card-panel admin-panel">
        <div class="panel-heading">
            <p class="dashboard-kicker">Danh sách</p>
            <h2 class="section-title">Tài liệu khả dụng</h2>
        </div>
        <div class="table-responsive">
            <table class="table admin-table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Tiêu đề</th>
                        <th>Môn học</th>
                        <th>Bộ môn</th>
                        <th>Ngày upload</th>
                        <th>Cảnh báo</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Documents.Count == 0)
                {
                    <tr>
                        <td colspan="6" class="text-muted">Chưa có tài liệu học tập khả dụng.</td>
                    </tr>
                }
                else
                {
                    @foreach (var document in Model.Documents)
                    {
                        <tr>
                            <td><strong>@document.Title</strong></td>
                            <td>@document.SubjectName</td>
                            <td>@document.DepartmentName</td>
                            <td>@document.UploadedAtUtc.ToLocalTime().ToString("g")</td>
                            <td>
                                @if (document.ScheduledArchiveAtUtc.HasValue)
                                {
                                    <div class="archive-warning">
                                        <span class="badge text-bg-warning">Sắp bị ẩn</span>
                                        <small>@FormatArchiveWarning(document.ScheduledArchiveAtUtc.Value)</small>
                                    </div>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>
                                <div class="btn-group btn-group-sm" role="group">
                                    <a class="btn btn-outline-primary" asp-action="Details" asp-route-id="@document.Id">Xem</a>
                                    <a class="btn btn-outline-primary" asp-action="Download" asp-route-id="@document.Id">Tải xuống</a>
                                </div>
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </section>
</div>

@functions {
    private static string FormatArchiveWarning(DateTime scheduledArchiveAtUtc)
    {
        var localTime = scheduledArchiveAtUtc.ToLocalTime();
        var remaining = scheduledArchiveAtUtc - DateTime.UtcNow;

        if (remaining.TotalDays >= 1)
        {
            return $"Ẩn lúc {localTime:g} (còn {Math.Ceiling(remaining.TotalDays):0} ngày)";
        }

        if (remaining.TotalHours >= 1)
        {
            return $"Ẩn lúc {localTime:g} (còn {Math.Ceiling(remaining.TotalHours):0} giờ)";
        }

        return $"Ẩn lúc {localTime:g}";
    }
}

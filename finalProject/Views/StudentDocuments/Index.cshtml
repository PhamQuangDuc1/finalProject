@model IReadOnlyList<BLL.DTOs.DocumentDto>

@{
    ViewData["Title"] = "Tài liệu học tập";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h1 class="h3 mb-1">Tài liệu học tập</h1>
        <p class="text-muted mb-0">Chỉ hiển thị tài liệu đã index, môn học đang hoạt động và chưa archive.</p>
    </div>
</div>

@if (TempData["StatusMessage"] is string statusMessage)
{
    <div class="alert alert-info" role="alert">@statusMessage</div>
}

<section class="card-panel">
    <div class="table-responsive">
        <table class="table table-striped align-middle mb-0">
            <thead>
                <tr>
                    <th>Tiêu đề</th>
                    <th>Môn học</th>
                    <th>Bộ môn</th>
                    <th>Ngày upload</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Count == 0)
            {
                <tr>
                    <td colspan="5" class="text-muted">Chưa có tài liệu học tập khả dụng.</td>
                </tr>
            }
            else
            {
                @foreach (var document in Model)
                {
                    <tr>
                        <td>@document.Title</td>
                        <td>@document.SubjectName</td>
                        <td>@document.DepartmentName</td>
                        <td>@document.UploadedAtUtc.ToLocalTime().ToString("g")</td>
                        <td>
                            <div class="btn-group btn-group-sm" role="group">
                                <a class="btn btn-outline-primary" asp-action="ViewDocument" asp-route-id="@document.Id">Xem</a>
                                <a class="btn btn-outline-primary" asp-action="Download" asp-route-id="@document.Id">Tải xuống</a>
                            </div>
                        </td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
</section>

@model IReadOnlyList<BLL.DTOs.DocumentDto>

@{
    ViewData["Title"] = "T\u00E0i li\u1EC7u h\u1ECDc t\u1EADp";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h1 class="h3 mb-1">T&agrave;i li&#7879;u h&#7885;c t&#7853;p</h1>
        <p class="text-muted mb-0">Ch&#7881; hi&#7875;n th&#7883; t&agrave;i li&#7879;u &#273;&atilde; index, m&ocirc;n h&#7885;c &#273;ang ho&#7841;t &#273;&#7897;ng v&agrave; ch&#432;a archive.</p>
    </div>
</div>

@if (TempData["StatusMessage"] is string statusMessage)
{
    <div class="alert alert-info" role="alert">@statusMessage</div>
}

<section class="card-panel">
    <div class="table-responsive">
        <table class="table table-striped align-middle mb-0">
            <thead>
                <tr>
                    <th>Ti&ecirc;u &#273;&#7873;</th>
                    <th>M&ocirc;n h&#7885;c</th>
                    <th>B&#7897; m&ocirc;n</th>
                    <th>Ng&agrave;y upload</th>
                    <th>C&#7843;nh b&aacute;o</th>
                    <th>Thao t&aacute;c</th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Count == 0)
            {
                <tr>
                    <td colspan="6" class="text-muted">Ch&#432;a c&oacute; t&agrave;i li&#7879;u h&#7885;c t&#7853;p kh&#7843; d&#7909;ng.</td>
                </tr>
            }
            else
            {
                @foreach (var document in Model)
                {
                    <tr>
                        <td>@document.Title</td>
                        <td>@document.SubjectName</td>
                        <td>@document.DepartmentName</td>
                        <td>@document.UploadedAtUtc.ToLocalTime().ToString("g")</td>
                        <td>
                            @if (document.ScheduledArchiveAtUtc.HasValue)
                            {
                                <div class="archive-warning">
                                    <span class="badge text-bg-warning">S&#7855;p b&#7883; &#7849;n</span>
                                    <small>@FormatArchiveWarning(document.ScheduledArchiveAtUtc.Value)</small>
                                </div>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <td>
                            <div class="btn-group btn-group-sm" role="group">
                                <a class="btn btn-outline-primary" asp-action="Details" asp-route-id="@document.Id">Xem</a>
                                <a class="btn btn-outline-primary" asp-action="Download" asp-route-id="@document.Id">T&#7843;i xu&#7889;ng</a>
                            </div>
                        </td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
</section>

@functions {
    private static string FormatArchiveWarning(DateTime scheduledArchiveAtUtc)
    {
        var localTime = scheduledArchiveAtUtc.ToLocalTime();
        var remaining = scheduledArchiveAtUtc - DateTime.UtcNow;

        if (remaining.TotalDays >= 1)
        {
            return $"\u1EA8n l\u00FAc {localTime:g} (c\u00F2n {Math.Ceiling(remaining.TotalDays):0} ng\u00E0y)";
        }

        if (remaining.TotalHours >= 1)
        {
            return $"\u1EA8n l\u00FAc {localTime:g} (c\u00F2n {Math.Ceiling(remaining.TotalHours):0} gi\u1EDD)";
        }

        return $"\u1EA8n l\u00FAc {localTime:g}";
    }
}

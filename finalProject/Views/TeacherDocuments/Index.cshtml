@model TeacherDocumentsIndexViewModel

@{
    var minimumArchiveAt = DateTime.Now.AddDays(7).ToString("yyyy-MM-ddTHH:mm");
    ViewData["Title"] = "Tài liệu của tôi";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h1 class="h3 mb-1">Tài liệu của tôi</h1>
        <p class="text-muted mb-0">Chỉ hiển thị tài liệu do chính giảng viên hiện tại upload.</p>
    </div>
    <a class="btn btn-primary" asp-controller="TeacherDocuments" asp-action="Upload">Tải tài liệu lên</a>
</div>

@if (TempData["StatusMessage"] is string statusMessage)
{
    <div class="alert alert-info" role="alert">@statusMessage</div>
}

<section class="card-panel mb-4" data-document-realtime="teacher">
    <div class="d-flex align-items-center justify-content-between mb-2">
        <h2 class="section-title mb-0">Realtime tài liệu của tôi</h2>
        <span class="badge text-bg-secondary" id="documentRealtimeStatus">Connecting</span>
    </div>
    <div class="table-responsive">
        <table class="table table-sm align-middle mb-0">
            <thead>
                <tr>
                    <th>Document</th>
                    <th>Subject</th>
                    <th>Action</th>
                    <th>Status</th>
                    <th>Time</th>
                </tr>
            </thead>
            <tbody id="documentRealtimeNotifications">
                <tr data-empty-realtime-row="true">
                    <td colspan="5" class="text-muted">Chưa có notification realtime trong phiên này.</td>
                </tr>
            </tbody>
        </table>
    </div>
</section>

<section class="card-panel mb-4">
    <form asp-action="Index" method="get" class="row g-3 align-items-end">
        <div class="col-md-3">
            <label asp-for="SubjectId" class="form-label">Môn học được phân công</label>
            <select asp-for="SubjectId" asp-items="Model.SubjectOptions" class="form-select">
                <option value="">Tất cả môn học</option>
            </select>
        </div>
        <div class="col-md-2">
            <label asp-for="Status" class="form-label">Trạng thái</label>
            <select asp-for="Status" asp-items="Model.StatusOptions" class="form-select">
                <option value="">Tất cả trạng thái</option>
            </select>
        </div>
        <div class="col-md-2">
            <label asp-for="ChapterId" class="form-label">Chương</label>
            <select asp-for="ChapterId" asp-items="Model.ChapterOptions" class="form-select">
                <option value="">Tất cả chương</option>
            </select>
        </div>
        <div class="col-md-3">
            <label asp-for="Search" class="form-label">Tìm kiếm</label>
            <input asp-for="Search" class="form-control" placeholder="Tiêu đề, tên tệp..." />
        </div>
        <div class="col-md-2 d-flex gap-2">
            <button type="submit" class="btn btn-primary flex-fill">Lọc</button>
            <a class="btn btn-outline-secondary" asp-action="Index">Xóa</a>
        </div>
    </form>
</section>

<section class="card-panel">
    <div class="table-responsive">
        <table class="table table-striped align-middle mb-0">
            <thead>
                <tr>
                    <th>Tiêu đề</th>
                    <th>Môn học</th>
                    <th>Bộ môn</th>
                    <th>Chương</th>
                    <th>Tệp</th>
                    <th>Trạng thái</th>
                    <th>Số chunk</th>
                    <th>Ngày upload</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody data-documents-table-body>
            @if (Model.Documents.Count == 0)
            {
                <tr data-empty-documents-row="true">
                    <td colspan="9" class="text-muted">Không có tài liệu phù hợp.</td>
                </tr>
            }
            else
            {
                @foreach (var document in Model.Documents)
                {
                    <tr data-document-id="@document.Id">
                        <td>@document.Title</td>
                        <td>@document.SubjectName</td>
                        <td>@document.DepartmentName</td>
                        <td>@(string.IsNullOrWhiteSpace(document.ChapterName) ? "Chưa gán" : document.ChapterName)</td>
                        <td>@document.FileName</td>
                        <td data-document-status>@document.Status</td>
                        <td>@document.ChunkCount</td>
                        <td>@document.UploadedAtUtc.ToLocalTime().ToString("g")</td>
                        <td>
                            <div class="d-flex flex-wrap gap-1">
                                <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@document.Id">Xem</a>
                                <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@document.Id">Sửa</a>
                                <a class="btn btn-sm btn-outline-primary" asp-action="Download" asp-route-id="@document.Id">Tải xuống</a>
                                <form asp-action="Archive" asp-route-id="@document.Id" method="post" class="d-flex gap-1">
                                    <input name="scheduledArchiveAt" type="datetime-local" class="form-control form-control-sm" min="@minimumArchiveAt" required disabled="@document.IsArchived" />
                                    <button type="submit" class="btn btn-sm btn-outline-warning" disabled="@document.IsArchived">Len lich an</button>
                                </form>
                                <form asp-action="Reindex" asp-route-id="@document.Id" method="post">
                                    <button type="submit" class="btn btn-sm btn-outline-secondary">Re-index</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
</section>

@model DocumentEditViewModel

@{
    ViewData["Title"] = "Sửa tài liệu";
}

<section class="card-panel col-lg-10">
    <h1 class="section-title">Sửa tài liệu</h1>
    <form asp-action="Edit" method="post">
        <input asp-for="Id" type="hidden" />
        <input asp-for="OriginalFileName" type="hidden" />
        <input asp-for="CurrentStatus" type="hidden" />
        <input asp-for="ContentVersion" type="hidden" />
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="alert alert-warning" role="alert">
            Việc lưu thay đổi sẽ cập nhật nội dung tài liệu và tạo lại các đoạn dữ liệu đã index.
        </div>

        <div class="row g-3 mb-3">
            <div class="col-md-6">
                <div class="text-muted">File gốc</div>
                <div class="fw-semibold">@Model.OriginalFileName</div>
            </div>
            <div class="col-md-6">
                <div class="text-muted">Trạng thái hiện tại</div>
                <div class="fw-semibold">@Model.CurrentStatus</div>
            </div>
        </div>

        <div class="mb-3">
            <label asp-for="Title" class="form-label"></label>
            <input asp-for="Title" class="form-control" />
            <span asp-validation-for="Title" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="SubjectId" class="form-label"></label>
            <select asp-for="SubjectId" asp-items="Model.SubjectOptions" class="form-select">
                <option value="">Chọn môn học được phân công</option>
            </select>
            <span asp-validation-for="SubjectId" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="ChapterName" class="form-label"></label>
            <input asp-for="ChapterName" class="form-control" placeholder="Nhập tên chương, ví dụ: Chương 1" />
            <div class="form-text">Nếu chương chưa tồn tại trong môn học đã chọn, hệ thống sẽ tự tạo chương mới.</div>
            <span asp-validation-for="ChapterName" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Description" class="form-label"></label>
            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Content" class="form-label"></label>
            <textarea asp-for="Content" class="form-control" rows="25"></textarea>
            <span asp-validation-for="Content" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
        <a class="btn btn-outline-secondary" asp-action="Details" asp-route-id="@Model.Id">Hủy</a>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

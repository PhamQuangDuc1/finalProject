@model DocumentEditViewModel

@{
    ViewData["Title"] = "Sửa tài liệu";
}

<section class="card-panel col-lg-8">
    <h1 class="section-title">Sửa tài liệu</h1>
    <form asp-action="Edit" method="post">
        <input asp-for="Id" type="hidden" />
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label asp-for="Title" class="form-label"></label>
            <input asp-for="Title" class="form-control" />
            <span asp-validation-for="Title" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="SubjectId" class="form-label"></label>
            <select asp-for="SubjectId" asp-items="Model.SubjectOptions" class="form-select">
                <option value="">Chọn môn học được phân công</option>
            </select>
            <span asp-validation-for="SubjectId" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="ChapterId" class="form-label"></label>
            <select asp-for="ChapterId" asp-items="Model.ChapterOptions" class="form-select">
                <option value="">Không gán chương</option>
            </select>
            <span asp-validation-for="ChapterId" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Description" class="form-label"></label>
            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-primary">Lưu</button>
        <a class="btn btn-outline-secondary" asp-action="Details" asp-route-id="@Model.Id">Hủy</a>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

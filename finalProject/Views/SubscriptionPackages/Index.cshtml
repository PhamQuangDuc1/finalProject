@model IReadOnlyList<BLL.DTOs.SubscriptionPackageDto>

@{
    ViewData["Title"] = "Gói đăng ký";
}

<div class="admin-page">
    <div class="admin-hero">
        <div>
            <p class="dashboard-kicker">Gói dịch vụ</p>
            <h1>Gói đăng ký</h1>
            <p>Quản lý các gói đăng ký mà giảng viên và sinh viên có thể mua để sử dụng dịch vụ AI.</p>
        </div>
        <a class="btn btn-primary admin-primary-action" asp-action="Create">Tạo gói đăng ký</a>
    </div>

    @if (TempData["StatusMessage"] is string statusMessage)
    {
        <div class="alert alert-success" role="alert">@statusMessage</div>
    }

    <section class="card-panel admin-panel">
        <div class="panel-heading">
            <p class="dashboard-kicker">Danh sách</p>
            <h2 class="section-title">Các gói đang có trong hệ thống</h2>
        </div>
        <div class="table-responsive">
            <table class="table admin-table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Tên gói</th>
                        <th>Giá</th>
                        <th>Thời hạn</th>
                        <th>Token tối đa</th>
                        <th>Số lượt mua</th>
                        <th>Trạng thái</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Count == 0)
                {
                    <tr>
                        <td colspan="7" class="text-muted">Chưa có gói đăng ký nào được tạo.</td>
                    </tr>
                }
                else
                {
                    @foreach (var package in Model)
                    {
                        <tr>
                            <td>
                                <strong>@package.Name</strong>
                                @if (!string.IsNullOrWhiteSpace(package.Description))
                                {
                                    <div class="text-muted small">@package.Description</div>
                                }
                            </td>
                            <td>@package.Price.ToString("N0") đ</td>
                            <td>@package.DurationDays ngày</td>
                            <td>@package.MaxTokens.ToString("N0")</td>
                            <td>@package.NumberOfPayments</td>
                            <td>
                                <span class="badge rounded-pill @(package.IsActive ? "text-bg-success" : "text-bg-secondary")">
                                    @(package.IsActive ? "Đang hoạt động" : "Đã tạm ngưng")
                                </span>
                            </td>
                            <td>
                                <div class="admin-actions">
                                    <div class="btn-group btn-group-sm" role="group">
                                        <a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@package.Id">Sửa</a>
                                    </div>
                                    <form asp-action="@(package.IsActive ? "Deactivate" : "Activate")" asp-route-id="@package.Id" method="post" class="d-inline">
                                        <button type="submit" class="btn btn-sm @(package.IsActive ? "btn-outline-warning" : "btn-outline-success")">
                                            @(package.IsActive ? "Tạm ngưng" : "Kích hoạt")
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </section>
</div>
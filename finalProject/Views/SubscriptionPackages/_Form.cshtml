@model SubscriptionPackageFormViewModel

<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
<div class="mb-3">
    <label asp-for="Name" class="form-label"></label>
    <input asp-for="Name" class="form-control" />
    <span asp-validation-for="Name" class="text-danger"></span>
</div>
<div class="mb-3">
    <label asp-for="Description" class="form-label"></label>
    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
    <span asp-validation-for="Description" class="text-danger"></span>
</div>
<div class="row">
    <div class="col-md-4 mb-3">
        <label asp-for="Price" class="form-label"></label>
        <input asp-for="Price" class="form-control" type="number" min="0" step="1000" />
        <span asp-validation-for="Price" class="text-danger"></span>
    </div>
    <div class="col-md-4 mb-3">
        <label asp-for="DurationDays" class="form-label"></label>
        <input asp-for="DurationDays" class="form-control" type="number" min="1" max="3650" />
        <span asp-validation-for="DurationDays" class="text-danger"></span>
    </div>
    <div class="col-md-4 mb-3">
        <label asp-for="MaxTokens" class="form-label"></label>
        <input asp-for="MaxTokens" class="form-control" type="number" min="0" />
        <span asp-validation-for="MaxTokens" class="text-danger"></span>
    </div>
</div>
<div class="form-check mb-3">
    <input asp-for="IsActive" class="form-check-input" />
    <label asp-for="IsActive" class="form-check-label"></label>
</div>
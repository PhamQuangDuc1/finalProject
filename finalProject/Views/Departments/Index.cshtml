@model IReadOnlyList<BLL.DTOs.DepartmentDto>

@{
    ViewData["Title"] = "Bộ môn";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <h1 class="h3 mb-0">Bộ môn</h1>
    <a class="btn btn-primary" asp-action="Create">Tạo bộ môn</a>
</div>

<section class="card-panel">
    <div class="table-responsive">
        <table class="table table-striped align-middle mb-0">
            <thead>
                <tr>
                    <th>Mã bộ môn</th>
                    <th>Tên bộ môn</th>
                    <th>Giảng viên quản lý</th>
                    <th>Số môn học</th>
                    <th>Ngày tạo</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Count == 0)
            {
                <tr>
                    <td colspan="6" class="text-muted">Chưa có bộ môn nào được tạo.</td>
                </tr>
            }
            else
            {
                @foreach (var department in Model)
                {
                    <tr>
                        <td>@department.Code</td>
                        <td>@department.Name</td>
                        <td>@(string.IsNullOrWhiteSpace(department.ManagerTeacherName) ? "Chưa có" : department.ManagerTeacherName)</td>
                        <td>@department.NumberOfSubjects</td>
                        <td>@department.CreatedAt.ToLocalTime().ToString("g")</td>
                        <td>
                            <div class="btn-group btn-group-sm" role="group">
                                <a class="btn btn-outline-primary" asp-action="Details" asp-route-id="@department.Id">Chi tiết</a>
                                <a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@department.Id">Sửa</a>
                                <a class="btn btn-outline-primary" asp-action="AssignManager" asp-route-id="@department.Id">Quản lý bộ môn</a>
                            </div>
                        </td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
</section>

@model IReadOnlyList<BLL.DTOs.DepartmentDto>

@{
    ViewData["Title"] = "Bộ môn";
}

<div class="admin-page">
    <div class="admin-hero">
        <div>
            <p class="dashboard-kicker">Cấu trúc đào tạo</p>
            <h1>Bộ môn</h1>
            <p>Quản lý bộ môn, giảng viên phụ trách và số lượng môn học đang vận hành.</p>
        </div>
        <a class="btn btn-primary admin-primary-action" asp-action="Create">Tạo bộ môn</a>
    </div>

    <section class="card-panel admin-panel">
        <div class="panel-heading">
            <p class="dashboard-kicker">Danh sách</p>
            <h2 class="section-title">Bộ môn trong hệ thống</h2>
        </div>
        <div class="table-responsive">
            <table class="table admin-table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Mã bộ môn</th>
                        <th>Tên bộ môn</th>
                        <th>Giảng viên quản lý</th>
                        <th>Số môn học</th>
                        <th>Ngày tạo</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Count == 0)
                {
                    <tr>
                        <td colspan="6" class="text-muted">Chưa có bộ môn nào được tạo.</td>
                    </tr>
                }
                else
                {
                    @foreach (var department in Model)
                    {
                        <tr>
                            <td><span class="admin-code">@department.Code</span></td>
                            <td><strong>@department.Name</strong></td>
                            <td>@(string.IsNullOrWhiteSpace(department.ManagerTeacherName) ? "Chưa có" : department.ManagerTeacherName)</td>
                            <td>@department.NumberOfSubjects</td>
                            <td>@department.CreatedAt.ToLocalTime().ToString("g")</td>
                            <td>
                                <div class="btn-group btn-group-sm" role="group">
                                    <a class="btn btn-outline-primary" asp-action="Details" asp-route-id="@department.Id">Chi tiết</a>
                                    <a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@department.Id">Sửa</a>
                                    <a class="btn btn-outline-primary" asp-action="AssignManager" asp-route-id="@department.Id">Quản lý</a>
                                </div>
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </section>
</div>

@model BLL.DTOs.DocumentDto

@{
    ViewData["Title"] = "Chi tiết tài liệu";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h1 class="h3 mb-1" data-document-title>@Model.Title</h1>
        <p class="text-muted mb-0">
            <span data-document-subject>@Model.SubjectName</span> - <span data-document-teacher>@Model.UploadedByTeacherName</span>
        </p>
    </div>
    <div class="d-flex flex-wrap gap-2">
        <a class="btn btn-outline-secondary" asp-action="Index">Quay lại</a>
        <a class="btn btn-outline-primary" asp-action="Download" asp-route-id="@Model.Id">Tải xuống file gốc</a>
    </div>
</div>

@if (Model.HasManualEdits)
{
    <div class="alert alert-warning" role="alert">
        Nội dung đã được giảng viên chỉnh sửa. Admin chỉ xem, không chỉnh sửa nội dung tài liệu.
    </div>
}

<section class="card-panel mb-4">
    <h2 class="section-title">Thông tin tài liệu</h2>
    <div class="row g-3">
        <div class="col-md-6"><div class="text-muted">Môn học</div><div class="fw-semibold">@Model.SubjectName</div></div>
        <div class="col-md-6"><div class="text-muted">Bộ môn</div><div class="fw-semibold">@Model.DepartmentName</div></div>
        <div class="col-md-6"><div class="text-muted">Người tải lên</div><div class="fw-semibold">@Model.UploadedByTeacherName</div></div>
        <div class="col-md-6"><div class="text-muted">Trạng thái</div><div class="fw-semibold" data-document-status-detail>@Model.Status</div></div>
        <div class="col-md-6"><div class="text-muted">File gốc</div><div class="fw-semibold">@Model.FileName</div></div>
        <div class="col-md-6"><div class="text-muted">Số đoạn dữ liệu</div><div class="fw-semibold" data-document-chunk-count>@Model.ChunkCount</div></div>
        <div class="col-md-6"><div class="text-muted">Phiên bản nội dung</div><div class="fw-semibold" data-document-content-version>@Model.ContentVersion</div></div>
        <div class="col-md-6"><div class="text-muted">Ngày tải lên</div><div class="fw-semibold">@Model.UploadedAtUtc.ToLocalTime().ToString("g")</div></div>
        <div class="col-md-6 @(Model.ContentUpdatedAtUtc.HasValue ? string.Empty : "d-none")" data-document-content-updated-wrapper>
            <div class="text-muted">Cập nhật nội dung</div>
            <div class="fw-semibold" data-document-content-updated>@(Model.ContentUpdatedAtUtc.HasValue ? Model.ContentUpdatedAtUtc.Value.ToLocalTime().ToString("g") : string.Empty)</div>
        </div>
        @if (Model.ArchivedAtUtc.HasValue)
        {
            <div class="col-md-6"><div class="text-muted">Lưu trữ lúc</div><div class="fw-semibold">@Model.ArchivedAtUtc.Value.ToLocalTime().ToString("g")</div></div>
        }
    </div>
</section>

<section class="card-panel mb-4">
    <h2 class="section-title">Mô tả</h2>
    <p class="mb-0" data-document-description>@(string.IsNullOrWhiteSpace(Model.Description) ? "Chưa có mô tả." : Model.Description)</p>
</section>

<partial name="_DocumentChunks" model="Model" />
<section class="card-panel mb-4">
    <h2 class="section-title">Nội dung hiện tại</h2>
    <div data-document-current-content>
        @if (string.IsNullOrWhiteSpace(Model.CurrentContent))
        {
            <p class="text-muted mb-0">Chưa có nội dung được trích xuất.</p>
        }
        else
        {
            <pre class="mb-0 p-3 bg-light border rounded text-wrap" style="white-space: pre-wrap;">@Model.CurrentContent</pre>
        }
    </div>
</section>

@if (Model.Versions.Count > 0)
{
    <section class="card-panel">
        <h2 class="section-title">Lịch sử phiên bản</h2>
        <div class="table-responsive">
            <table class="table table-striped align-middle mb-0">
                <thead>
                    <tr>
                        <th>Phiên bản</th>
                        <th>Ngày chỉnh sửa</th>
                        <th>Người chỉnh sửa</th>
                        <th>Ghi chú</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var version in Model.Versions)
                {
                    <tr>
                        <td>Phiên bản @version.VersionNumber</td>
                        <td>@version.UpdatedAtUtc.ToLocalTime().ToString("g")</td>
                        <td>@version.UpdatedByTeacherName</td>
                        <td>@version.ChangeNote</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </section>
}

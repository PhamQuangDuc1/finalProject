@model BLL.DTOs.DocumentDto

@{
    ViewData["Title"] = "Chi tiết tài liệu";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h1 class="h3 mb-1">@Model.Title</h1>
        <p class="text-muted mb-0">@Model.SubjectName - @Model.UploadedByTeacherName</p>
    </div>
    <div class="d-flex flex-wrap gap-2">
        <a class="btn btn-outline-secondary" asp-action="Index">Quay lại</a>
        <a class="btn btn-outline-primary" asp-action="Download" asp-route-id="@Model.Id">Tải xuống</a>
    </div>
</div>

<section class="card-panel mb-4">
    <h2 class="section-title">Thông tin tài liệu</h2>
    <div class="row g-3">
        <div class="col-md-6"><div class="text-muted">Môn học</div><div class="fw-semibold">@Model.SubjectName</div></div>
        <div class="col-md-6"><div class="text-muted">Bộ môn</div><div class="fw-semibold">@Model.DepartmentName</div></div>
        <div class="col-md-6"><div class="text-muted">Người upload</div><div class="fw-semibold">@Model.UploadedByTeacherName</div></div>
        <div class="col-md-6"><div class="text-muted">Trạng thái</div><div class="fw-semibold">@Model.Status</div></div>
        <div class="col-md-6"><div class="text-muted">Tên tệp</div><div class="fw-semibold">@Model.FileName</div></div>
        <div class="col-md-6"><div class="text-muted">Số chunk</div><div class="fw-semibold">@Model.ChunkCount</div></div>
        <div class="col-md-6"><div class="text-muted">Ngày upload</div><div class="fw-semibold">@Model.UploadedAtUtc.ToLocalTime().ToString("g")</div></div>
        @if (Model.ArchivedAtUtc.HasValue)
        {
            <div class="col-md-6"><div class="text-muted">Archive lúc</div><div class="fw-semibold">@Model.ArchivedAtUtc.Value.ToLocalTime().ToString("g")</div></div>
        }
    </div>
</section>

<section class="card-panel mb-4">
    <h2 class="section-title">Mô tả</h2>
    <p class="mb-0">@(string.IsNullOrWhiteSpace(Model.Description) ? "Chưa có mô tả." : Model.Description)</p>
</section>

<partial name="_DocumentChunks" model="Model" />

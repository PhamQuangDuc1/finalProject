@model IReadOnlyList<BLL.DTOs.DocumentDto>

@{
    ViewData["Title"] = "Quản lý tài liệu";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <h1 class="h3 mb-0">Quản lý tài liệu</h1>
    <span class="text-muted">Admin chỉ xem tổng quan tài liệu</span>
</div>

@if (TempData["StatusMessage"] is string statusMessage)
{
    <div class="alert alert-info" role="alert">@statusMessage</div>
}

<div class="table-responsive">
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>Tiêu đề</th>
                <th>Môn học</th>
                <th>Giảng viên</th>
                <th>Tệp</th>
                <th>Trạng thái</th>
                <th>Ngày tải lên</th>
            </tr>
        </thead>
        <tbody>
        @if (Model.Count == 0)
        {
            <tr>
                <td colspan="6" class="text-muted">Chưa có tài liệu nào được đăng ký.</td>
            </tr>
        }
        else
        {
            @foreach (var document in Model)
            {
                <tr>
                    <td>@document.Title</td>
                    <td>@document.SubjectName</td>
                    <td>@document.UploadedByTeacherName</td>
                    <td>@document.FileName</td>
                    <td>@document.Status</td>
                    <td>@document.UploadedAtUtc.ToLocalTime().ToString("g")</td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

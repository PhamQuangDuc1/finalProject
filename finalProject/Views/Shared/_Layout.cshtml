<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - StudyMate AI</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/finalProject.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="@(User.Identity?.IsAuthenticated == true ? "app-shell" : "auth-shell")">
        @if (User.Identity?.IsAuthenticated == true)
        {
            <aside class="sidebar">
                <a class="brand" asp-controller="Dashboard" asp-action="Index">StudyMate AI</a>
                <nav class="sidebar-nav">
                    <a asp-controller="Dashboard" asp-action="Index">Bảng điều khiển</a>

                    @if (User.IsInRole(StudyMateRoles.Admin))
                    {
                        <a asp-controller="Documents" asp-action="Index">Tài liệu</a>
                        <a asp-controller="Departments" asp-action="Index">Bộ môn</a>
                        <a asp-controller="Subjects" asp-action="Index">Môn học</a>
                        <a asp-controller="TeacherAssignments" asp-action="Index">Phân công giảng viên</a>
                        <a asp-controller="ChunkConfigurations" asp-action="Index">Cấu hình Chunk</a>
                        <a asp-controller="TokenUsage" asp-action="Index">Thống kê AI &amp; chi phí</a>
                        <a asp-controller="SubscriptionPackages" asp-action="Index">Gói đăng ký</a>
                        <a asp-controller="Payments" asp-action="Manage">Quản lý thanh toán</a>
                        <a asp-controller="AdminAccounts" asp-action="Index">Quản lý tài khoản</a>
                        <a asp-controller="AdminUsers" asp-action="Index">Quản lý gói người dùng</a>
                    }

                    @if (User.IsInRole(StudyMateRoles.Teacher))
                    {
                        <a asp-controller="TeacherDocuments" asp-action="Index">Tài liệu của tôi</a>
                        <a asp-controller="TeacherDocuments" asp-action="Upload">Tải tài liệu lên</a>
                        <a asp-controller="Payments" asp-action="Index">Gói đăng ký của tôi</a>
                    }

                    @if (User.IsInRole(StudyMateRoles.Student))
                    {
                        <a asp-controller="StudentDocuments" asp-action="Index">Tài liệu học tập</a>
                        <a asp-controller="Payments" asp-action="Index">Gói đăng ký của tôi</a>
                    }
                </nav>
            </aside>
        }

        <div class="app-main">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <header class="topbar">
                    <div>
                        <div class="page-kicker">StudyMate AI</div>
                        <div class="page-title">@ViewData["Title"]</div>
                    </div>
                    <div class="topbar-user">
                        <vc:user-token-summary />
                        <span>@User.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value</span>
                        <form asp-controller="Account" asp-action="Logout" method="post">
                            <button type="submit" class="btn btn-outline-primary btn-sm">Đăng xuất</button>
                        </form>
                    </div>
                </header>
            }

            <main class="@(User.Identity?.IsAuthenticated == true ? "content" : "auth-content")">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <script src="~/js/document-realtime.js" asp-append-version="true"></script>
    }
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

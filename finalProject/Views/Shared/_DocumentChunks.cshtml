@model BLL.DTOs.DocumentDto

<section class="card-panel mb-4" data-document-detail-id="@Model.Id">
    <div class="d-flex align-items-center justify-content-between gap-3 mb-3">
        <div>
            <h2 class="section-title mb-1">Noi dung da chunk</h2>
            <p class="text-muted mb-0">Dang hien thi @Model.Chunks.Count chunk theo thu tu index.</p>
        </div>
        <span class="badge text-bg-secondary" id="documentRealtimeStatus">Connecting</span>
    </div>

    <div class="alert alert-info d-none" data-document-detail-alert role="alert"></div>

    @if (Model.Chunks.Count == 0)
    {
        <p class="text-muted mb-0">Tai lieu nay chua co chunk de hien thi.</p>
    }
    else
    {
        <div class="chunk-list">
            @foreach (var chunk in Model.Chunks)
            {
                <article class="chunk-item">
                    <div class="chunk-meta">
                        <strong>Chunk #@chunk.ChunkIndex</strong>
                        <span>@chunk.WordCount word</span>
                        <span>@chunk.TokenCount token</span>
                        <span>Vi tri @chunk.StartPosition-@chunk.EndPosition</span>
                    </div>
                    <pre class="chunk-content">@chunk.Content</pre>
                </article>
            }
        </div>
    }
</section>

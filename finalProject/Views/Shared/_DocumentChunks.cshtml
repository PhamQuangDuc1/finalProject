@model BLL.DTOs.DocumentDto

<section class="card-panel mb-4" data-document-detail-id="@Model.Id" data-document-snapshot-url="@Url.Action("RealtimeSnapshot", "Documents", new { id = Model.Id })">
    <div class="d-flex align-items-center justify-content-between gap-3 mb-3">
        <div>
            <h2 class="section-title mb-1">Nội dung đã chunk</h2>
            <p class="text-muted mb-0" data-document-chunk-summary>Đang hiển thị @Model.Chunks.Count chunk theo thứ tự index.</p>
        </div>
        <span class="badge text-bg-secondary" id="documentRealtimeStatus">Đang kết nối</span>
    </div>

    <div class="alert alert-info d-none" data-document-detail-alert role="alert"></div>

    <div data-document-chunks>
        @if (Model.Chunks.Count == 0)
        {
            <p class="text-muted mb-0">Tài liệu này chưa có chunk để hiển thị.</p>
        }
        else
        {
            <div class="chunk-list">
            @foreach (var chunk in Model.Chunks)
            {
                <article class="chunk-item">
                    <div class="chunk-meta">
                        <strong>Chunk #@chunk.ChunkIndex</strong>
                        <span>@chunk.WordCount word</span>
                        <span>@chunk.TokenCount token</span>
                        <span>Vị trí @chunk.StartPosition-@chunk.EndPosition</span>
                    </div>
                    <pre class="chunk-content">@chunk.Content</pre>
                </article>
            }
            </div>
        }
    </div>
</section>

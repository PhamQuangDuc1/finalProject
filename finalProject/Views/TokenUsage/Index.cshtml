@model IReadOnlyList<BLL.DTOs.TokenUsageMonthlySummaryDto>

@{
    ViewData["Title"] = "Thống kê token";
}

<h1 class="h3 mb-3">Thống kê token và chi phí AI</h1>

<table class="table table-striped align-middle">
    <thead>
        <tr>
            <th>Tháng</th>
            <th>Token đầu vào</th>
            <th>Token đầu ra</th>
            <th>Chi phí ước tính USD</th>
        </tr>
    </thead>
    <tbody>
    @if (Model.Count == 0)
    {
        <tr>
            <td colspan="4" class="text-muted">Chưa có dữ liệu sử dụng token.</td>
        </tr>
    }
    else
    {
        @foreach (var summary in Model)
        {
            <tr>
                <td>@summary.Month/@summary.Year</td>
                <td>@summary.PromptTokens</td>
                <td>@summary.CompletionTokens</td>
                <td>@summary.EstimatedCostUsd.ToString("0.000000")</td>
            </tr>
        }
    }
    </tbody>
</table>

@model AiUsageDashboardViewModel

@{
    ViewData["Title"] = "Thống kê AI & chi phí";
    var dailySummaries = Model.Dashboard.DailySummaries;
    var maxDailyTokens = Math.Max(1, dailySummaries.Count == 0 ? 0 : dailySummaries.Max(summary => summary.TotalTokens));
    var maxDailyCost = Math.Max(0.000001m, dailySummaries.Count == 0 ? 0 : dailySummaries.Max(summary => summary.EstimatedCost));
}

<div class="admin-page">
    <div class="admin-hero">
        <div>
            <p class="dashboard-kicker">Chi phí AI</p>
            <h1>Thống kê AI & chi phí ước tính</h1>
            <p>Theo dõi token, số lượt yêu cầu và chi phí ước tính từ AiUsageLog theo tháng, model và loại tác vụ.</p>
        </div>
        <div class="admin-hero-stat">
            <span>Chi phí tháng này</span>
            <strong class="text-success">$@Model.Dashboard.EstimatedCostThisMonth.ToString("0.000000")</strong>
        </div>
    </div>

    <section class="card-panel admin-panel">
        <div class="panel-heading">
            <p class="dashboard-kicker">Bộ lọc</p>
            <h2 class="section-title">Điều kiện thống kê</h2>
        </div>
        <form asp-action="Index" method="get" class="row g-3 align-items-end admin-form">
            <div class="col-md-3">
                <label asp-for="Month" class="form-label">Tháng</label>
                <select asp-for="Month" asp-items="Model.MonthOptions" class="form-select"></select>
            </div>
            <div class="col-md-4">
                <label asp-for="ModelName" class="form-label">Model</label>
                <select asp-for="ModelName" asp-items="Model.ModelOptions" class="form-select">
                    <option value="">Tất cả model</option>
                </select>
            </div>
            <div class="col-md-3">
                <label asp-for="OperationType" class="form-label">Loại tác vụ</label>
                <select asp-for="OperationType" asp-items="Model.OperationOptions" class="form-select">
                    <option value="">Tất cả tác vụ</option>
                </select>
            </div>
            <div class="col-md-2 d-flex gap-2">
                <button type="submit" class="btn btn-primary admin-primary-action flex-fill">Lọc</button>
                <a class="btn btn-outline-secondary" asp-action="Index">Xóa</a>
            </div>
        </form>
    </section>

    <section class="metric-grid dashboard-metrics">
        <div class="metric-card dashboard-metric-card">
            <span>Prompt tokens tháng này</span>
            <strong>@Model.Dashboard.TotalPromptTokensThisMonth.ToString("N0")</strong>
        </div>
        <div class="metric-card dashboard-metric-card">
            <span>Completion tokens tháng này</span>
            <strong>@Model.Dashboard.TotalCompletionTokensThisMonth.ToString("N0")</strong>
        </div>
        <div class="metric-card dashboard-metric-card">
            <span class="text-primary">Tổng Tokens tháng này</span>
            <strong class="text-primary">@Model.Dashboard.TotalTokensThisMonth.ToString("N0")</strong>
        </div>
        <div class="metric-card dashboard-metric-card">
            <span class="text-success">Chi phí ước tính tháng này</span>
            <strong class="text-success">$@Model.Dashboard.EstimatedCostThisMonth.ToString("0.000000")</strong>
        </div>
        <div class="metric-card dashboard-metric-card">
            <span>Yêu cầu tháng này</span>
            <strong>@Model.Dashboard.RequestsThisMonth.ToString("N0")</strong>
        </div>
        <div class="metric-card dashboard-metric-card">
            <span>Tokens trung bình mỗi yêu cầu</span>
            <strong>@Model.Dashboard.AverageTokensPerRequest.ToString("N2")</strong>
        </div>
    </section>

    <section class="card-panel admin-panel">
        <div class="panel-heading">
            <p class="dashboard-kicker">Theo ngày</p>
            <h2 class="section-title">Token và chi phí theo ngày</h2>
        </div>
        <div class="table-responsive">
            <table class="table admin-table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Ngày</th>
                        <th class="text-center">Prompt</th>
                        <th class="text-center">Completion</th>
                        <th class="text-primary text-center">Tổng Tokens</th>
                        <th class="text-center">Yêu cầu</th>
                        <th class="text-success text-center">Chi phí</th>
                        <th style="width: 32%">Mức sử dụng</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var summary in dailySummaries)
                {
                    var tokenWidth = summary.TotalTokens * 100m / maxDailyTokens;
                    var costWidth = summary.EstimatedCost * 100m / maxDailyCost;
                    <tr>
                        <td>@summary.Date.ToString("dd/MM/yyyy")</td>
                        <td class="text-center">@summary.PromptTokens.ToString("N0")</td>
                        <td class="text-center">@summary.CompletionTokens.ToString("N0")</td>
                        <td class="text-primary text-center fw-semibold">@summary.TotalTokens.ToString("N0")</td>
                        <td class="text-center">@summary.Requests.ToString("N0")</td>
                        <td class="text-success text-center fw-semibold">$@summary.EstimatedCost.ToString("0.000000")</td>
                        <td>
                            <div class="d-flex flex-column gap-2">
                                <div>
                                    <div class="d-flex justify-content-between small text-primary mb-1">
                                        <span>Token</span>
                                        <span>@summary.TotalTokens.ToString("N0")</span>
                                    </div>
                                    <div class="progress admin-progress">
                                        <div class="progress-bar bg-primary" style="width: @tokenWidth.ToString("0.##")%"></div>
                                    </div>
                                </div>
                                <div>
                                    <div class="d-flex justify-content-between small text-success mb-1">
                                        <span>Chi phí</span>
                                        <span>$@summary.EstimatedCost.ToString("0.000000")</span>
                                    </div>
                                    <div class="progress admin-progress">
                                        <div class="progress-bar bg-success" style="width: @costWidth.ToString("0.##")%"></div>
                                    </div>
                                </div>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </section>

    <section class="dashboard-grid dashboard-panels">
        <div class="card-panel admin-panel">
            <div class="panel-heading">
                <p class="dashboard-kicker">Model</p>
                <h2 class="section-title">Token theo model</h2>
            </div>
            <div class="table-responsive">
                <table class="table admin-table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Model</th>
                            <th class="text-primary text-center">Tổng Tokens</th>
                            <th class="text-center">Yêu cầu</th>
                            <th class="text-success text-center">Chi phí</th>
                        </tr>
                    </thead>
                    <tbody>
                    @if (Model.Dashboard.ModelSummaries.Count == 0)
                    {
                        <tr>
                            <td colspan="4" class="text-muted">Chưa có dữ liệu theo model.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var summary in Model.Dashboard.ModelSummaries)
                        {
                            <tr>
                                <td>@summary.ModelName</td>
                                <td class="text-primary text-center fw-semibold">@summary.TotalTokens.ToString("N0")</td>
                                <td class="text-center">@summary.Requests.ToString("N0")</td>
                                <td class="text-success text-center fw-semibold">$@summary.EstimatedCost.ToString("0.000000")</td>
                            </tr>
                        }
                    }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card-panel admin-panel">
            <div class="panel-heading">
                <p class="dashboard-kicker">Tác vụ</p>
                <h2 class="section-title">Token theo tác vụ</h2>
            </div>
            <div class="table-responsive">
                <table class="table admin-table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Tác vụ</th>
                            <th class="text-primary text-center">Tổng Tokens</th>
                            <th class="text-center">Yêu cầu</th>
                            <th class="text-success text-center">Chi phí</th>
                        </tr>
                    </thead>
                    <tbody>
                    @if (Model.Dashboard.OperationSummaries.Count == 0)
                    {
                        <tr>
                            <td colspan="4" class="text-muted">Chưa có dữ liệu theo tác vụ.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var summary in Model.Dashboard.OperationSummaries)
                        {
                            <tr>
                                <td>@GetOperationLabel(summary.OperationType)</td>
                                <td class="text-primary text-center fw-semibold">@summary.TotalTokens.ToString("N0")</td>
                                <td class="text-center">@summary.Requests.ToString("N0")</td>
                                <td class="text-success text-center fw-semibold">$@summary.EstimatedCost.ToString("0.000000")</td>
                            </tr>
                        }
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </section>
</div>

@functions {
    private static string GetOperationLabel(DAL.Entities.AiOperationType operationType)
    {
        return operationType switch
        {
            DAL.Entities.AiOperationType.DocumentEmbedding => "Embedding tài liệu",
            DAL.Entities.AiOperationType.ChatCompletion => "Chat AI",
            DAL.Entities.AiOperationType.ReIndexDocument => "Index lại tài liệu",
            DAL.Entities.AiOperationType.Benchmark => "Benchmark",
            _ => operationType.ToString()
        };
    }
}
